<?xml version="1.0" encoding="utf-8"?>
<!--
==============================================================
  INDIAN ARMY DIGITAL TACTICAL - Watch Face Format v2
  Canvas: 450x450  CX=225  CY=225

  USER CONFIGURATIONS
  1. accentColor  ColorConfig  (amber/green/blue/red/stealth)
     .0=primary LCD  .1=secondary  .2=frame/bezel
  2. bgTheme      ColorConfig  (tactical/stealth/urban)
     .0=scene bg  .1=panel bg  .2=panel stroke
  3. timeFormat   ListConfig   (24h=index0 / 12h=index1)
  4. showSeconds  BoolConfig   (TRUE=1 / FALSE=0)

  LAYOUT (450px canvas)
  y=30-38  Indian tricolor accent lines
  y=44-80  INDIAN ARMY header
  y=84-164 Sub-display  date + HR/STP complications
  y=172-262 Main time  ghost layer + active layer
  y=271-275 Divider double line
  y=283-352 Bottom panels  BATT / ALT / COMP
  y=360-388 Footer  === TACTICAL ===
==============================================================
-->
<WatchFace width="450" height="450">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="14:30:00" />

    <!-- ============================================================== -->
    <!-- USER CONFIGURATIONS                                            -->
    <!-- ============================================================== -->
    <UserConfigurations>

        <!--  LCD Accent Colour  (.0=primary .1=secondary .2=frame)  -->
        <ColorConfiguration
            id="accentColor"
            defaultValue="amber"
            displayName="@string/accent_color_label"
            screenReaderText="@string/accent_color_label">
            <ColorOption id="amber"   displayName="@string/color_amber"
                colors="#ffFF8C00 #ffCCAA00 #ff4A5D23" />
            <ColorOption id="green"   displayName="@string/color_green"
                colors="#ff4CAF50 #ff81C784 #ff2E7D32" />
            <ColorOption id="blue"    displayName="@string/color_blue"
                colors="#ff42A5F5 #ff90CAF9 #ff1565C0" />
            <ColorOption id="red"     displayName="@string/color_red"
                colors="#ffFF4444 #ffCC3333 #ff8B0000" />
            <ColorOption id="stealth" displayName="@string/color_stealth"
                colors="#ffDDDDDD #ffAAAAAA #ff555555" />
        </ColorConfiguration>

        <!--  Background Theme  (.0=scene-bg .1=panel-bg .2=panel-stroke)  -->
        <ColorConfiguration
            id="bgTheme"
            defaultValue="tactical"
            displayName="@string/bg_theme_label"
            screenReaderText="@string/bg_theme_label">
            <ColorOption id="tactical" displayName="@string/bg_tactical"
                colors="#ff0A0A0A #ff0D1A0D #ff3A4A2A" />
            <ColorOption id="stealth"  displayName="@string/bg_stealth"
                colors="#ff050505 #ff080808 #ff222222" />
            <ColorOption id="urban"    displayName="@string/bg_urban"
                colors="#ff111418 #ff1A1E22 #ff3A3E42" />
        </ColorConfiguration>

        <!--  Time Format  (index 0=24h  index 1=12h)  -->
        <ListConfiguration
            id="timeFormat"
            defaultValue="24h"
            displayName="@string/time_format_label"
            screenReaderText="@string/time_format_label">
            <ListOption id="24h" displayName="@string/time_24h" />
            <ListOption id="12h" displayName="@string/time_12h" />
        </ListConfiguration>

        <!--  Show/Hide Seconds  -->
        <BooleanConfiguration
            id="showSeconds"
            defaultValue="TRUE"
            displayName="@string/show_seconds_label"
            screenReaderText="@string/show_seconds_label" />

        <!--  Flavors - pre-set combos shown in picker carousel  -->
        <Flavors defaultValue="tactical_amber">
            <Flavor id="tactical_amber" displayName="@string/flavor_amber">
                <Configuration id="accentColor" optionId="amber" />
                <Configuration id="bgTheme"     optionId="tactical" />
            </Flavor>
            <Flavor id="tactical_green" displayName="@string/flavor_green">
                <Configuration id="accentColor" optionId="green" />
                <Configuration id="bgTheme"     optionId="tactical" />
            </Flavor>
            <Flavor id="stealth_black" displayName="@string/flavor_stealth">
                <Configuration id="accentColor" optionId="stealth" />
                <Configuration id="bgTheme"     optionId="stealth" />
            </Flavor>
            <Flavor id="urban_blue" displayName="@string/flavor_blue">
                <Configuration id="accentColor" optionId="blue" />
                <Configuration id="bgTheme"     optionId="urban" />
            </Flavor>
            <Flavor id="tactical_red" displayName="@string/flavor_red">
                <Configuration id="accentColor" optionId="red" />
                <Configuration id="bgTheme"     optionId="tactical" />
            </Flavor>
        </Flavors>

    </UserConfigurations>

    <!-- ============================================================== -->
    <!-- SCENE                                                          -->
    <!-- ============================================================== -->
    <Scene backgroundColor="[CONFIGURATION.bgTheme.0]">

        <!-- ========================================================== -->
        <!-- BEZEL - 5 rings + 12 tactical tick marks                   -->
        <!-- ========================================================== -->

        <!-- Outer ring group: always visible -->
        <PartDraw x="0" y="0" width="450" height="450">
            <!-- Outermost dark containment ring -->
            <Arc centerX="225" centerY="225" width="446" height="446"
                 startAngle="0" endAngle="360" direction="CLOCKWISE">
                <Stroke color="#ff1A1A1A" thickness="3" />
            </Arc>
            <!-- Primary accent ring - follows accentColor.2 (frame color) -->
            <Arc centerX="225" centerY="225" width="436" height="436"
                 startAngle="0" endAngle="360" direction="CLOCKWISE">
                <Stroke color="[CONFIGURATION.accentColor.2]" thickness="3" />
            </Arc>
            <!-- Thin dark separator -->
            <Arc centerX="225" centerY="225" width="426" height="426"
                 startAngle="0" endAngle="360" direction="CLOCKWISE">
                <Stroke color="#ff2A2A2A" thickness="1" />
            </Arc>
        </PartDraw>

        <!-- Inner double-ring - the design reference inner glow bezel -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Arc centerX="225" centerY="225" width="408" height="408"
                 startAngle="0" endAngle="360" direction="CLOCKWISE">
                <Stroke color="[CONFIGURATION.bgTheme.2]" thickness="1" />
            </Arc>
            <Arc centerX="225" centerY="225" width="402" height="402"
                 startAngle="0" endAngle="360" direction="CLOCKWISE">
                <Stroke color="[CONFIGURATION.accentColor.2]" thickness="2" />
            </Arc>
        </PartDraw>

        <!-- 12 tactical tick marks every 30 degrees - active only -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="0"   endAngle="2"   direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="30"  endAngle="32"  direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="60"  endAngle="62"  direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="90"  endAngle="92"  direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="120" endAngle="122" direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="150" endAngle="152" direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="180" endAngle="182" direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="210" endAngle="212" direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="240" endAngle="242" direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="270" endAngle="272" direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="300" endAngle="302" direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
            <Arc centerX="225" centerY="225" width="440" height="440" startAngle="330" endAngle="332" direction="CLOCKWISE"><Stroke color="[CONFIGURATION.accentColor.2]" thickness="8" /></Arc>
        </PartDraw>

        <!-- ========================================================== -->
        <!-- INDIAN TRICOLOR ACCENT LINES - active only                 -->
        <!-- ========================================================== -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Line startX="145" startY="30" endX="305" endY="30"><Stroke color="#ffFF9933" thickness="2" /></Line>
            <Line startX="145" startY="34" endX="305" endY="34"><Stroke color="#ffE8E8E8" thickness="1" /></Line>
            <Line startX="145" startY="38" endX="305" endY="38"><Stroke color="#ff138808" thickness="2" /></Line>
        </PartDraw>

        <!-- ========================================================== -->
        <!-- HEADER "INDIAN ARMY" - active only                         -->
        <!-- ========================================================== -->
        <PartText x="0" y="44" width="450" height="36">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="30" weight="BOLD"
                      letterSpacing="0.18" color="#ffE8E8E8">
                    <Template>INDIAN ARMY</Template>
                </Font>
            </Text>
        </PartText>

        <!-- ========================================================== -->
        <!-- SUB-DISPLAY: date + HR + steps - active only               -->
        <!-- ========================================================== -->
        <PartDraw x="60" y="84" width="330" height="80">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <RoundRectangle x="0" y="0" width="330" height="80" cornerRadiusX="4" cornerRadiusY="4">
                <Fill color="[CONFIGURATION.bgTheme.1]" />
                <Stroke color="[CONFIGURATION.bgTheme.2]" thickness="1" />
            </RoundRectangle>
        </PartDraw>

        <!-- Date line: TUE  03-MAR-2026 -->
        <PartText x="72" y="92" width="306" height="28">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Text align="START">
                <Font family="SYNC_TO_DEVICE" size="16" weight="BOLD"
                      letterSpacing="0.10" color="[CONFIGURATION.accentColor.1]">
                    <Template><![CDATA[%s  %s-%s-%d]]>
                        <Parameter expression="[DAY_OF_WEEK_S]" />
                        <Parameter expression="[DAY_Z]" />
                        <Parameter expression="[MONTH_S]" />
                        <Parameter expression="[YEAR]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <!-- Heart rate complication (slot 100) -->
        <ComplicationSlot slotId="100" x="72" y="124" width="180" height="28"
            name="@string/complication_hr"
            supportedTypes="SHORT_TEXT RANGED_VALUE">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <DefaultProviderPolicy defaultSystemDataSource="HEART_RATE"
                defaultDataSourceType="SHORT_TEXT" />
            <BoundingOval x="0" y="0" width="180" height="28" />
            <Complication type="SHORT_TEXT">
                <Text align="START">
                    <Font family="SYNC_TO_DEVICE" size="14" weight="NORMAL"
                          letterSpacing="0.06" color="[CONFIGURATION.accentColor.0]">
                        <Template><![CDATA[HR:%s BPM]]>
                            <Parameter expression="[COMPLICATION.TEXT]" />
                        </Template>
                    </Font>
                </Text>
            </Complication>
        </ComplicationSlot>

        <!-- Step count complication (slot 101) -->
        <ComplicationSlot slotId="101" x="260" y="124" width="120" height="28"
            name="@string/complication_steps"
            supportedTypes="SHORT_TEXT RANGED_VALUE">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <DefaultProviderPolicy defaultSystemDataSource="STEP_COUNT"
                defaultDataSourceType="SHORT_TEXT" />
            <BoundingOval x="0" y="0" width="120" height="28" />
            <Complication type="SHORT_TEXT">
                <Text align="START">
                    <Font family="SYNC_TO_DEVICE" size="14" weight="NORMAL"
                          letterSpacing="0.06" color="[CONFIGURATION.accentColor.0]">
                        <Template><![CDATA[STP:%s]]>
                            <Parameter expression="[COMPLICATION.TEXT]" />
                        </Template>
                    </Font>
                </Text>
            </Complication>
        </ComplicationSlot>

        <!-- ========================================================== -->
        <!-- MAIN TIME - 4 variants x 2 layers (ghost + active)         -->
        <!--                                                            -->
        <!--  Ghost layer alpha=18 (~7%) = authentic LCD shadow segs    -->
        <!--  Multiple Condition blocks AND together to hide/show vars  -->
        <!--                                                            -->
        <!--  A: 24H + seconds   (timeFormat=24h, showSeconds=TRUE)    -->
        <!--  B: 24H no seconds  (timeFormat=24h, showSeconds=FALSE)   -->
        <!--  C: 12H + seconds   (timeFormat=12h, showSeconds=TRUE)    -->
        <!--  D: 12H no seconds  (timeFormat=12h, showSeconds=FALSE)   -->
        <!-- ========================================================== -->

        <!-- A-GHOST: 24H with seconds -->
        <PartText x="0" y="172" width="450" height="90" alpha="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 1"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[CONFIGURATION.showSeconds] == 0"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="@font/dseg7" size="68" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template>88:88:88</Template>
                </Font>
            </Text>
        </PartText>
        <!-- A-ACTIVE: 24H with seconds -->
        <PartText x="0" y="172" width="450" height="90">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 1"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[CONFIGURATION.showSeconds] == 0"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="@font/dseg7" size="68" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template><![CDATA[%02d:%02d:%02d]]>
                        <Parameter expression="[HOUR_0_23_Z]" />
                        <Parameter expression="[MINUTE_Z]" />
                        <Parameter expression="[SECOND_Z]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <!-- B-GHOST: 24H no seconds -->
        <PartText x="0" y="172" width="450" height="90" alpha="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 1"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[CONFIGURATION.showSeconds] == 1"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="@font/dseg7" size="82" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template>88:88</Template>
                </Font>
            </Text>
        </PartText>
        <!-- B-ACTIVE: 24H no seconds (larger font) -->
        <PartText x="0" y="172" width="450" height="90">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 1"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[CONFIGURATION.showSeconds] == 1"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="@font/dseg7" size="82" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template><![CDATA[%02d:%02d]]>
                        <Parameter expression="[HOUR_0_23_Z]" />
                        <Parameter expression="[MINUTE_Z]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <!-- C-GHOST: 12H with seconds -->
        <PartText x="0" y="172" width="450" height="90" alpha="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 0"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[CONFIGURATION.showSeconds] == 0"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="@font/dseg7" size="68" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template>88:88:88</Template>
                </Font>
            </Text>
        </PartText>
        <!-- C-ACTIVE: 12H with seconds -->
        <PartText x="0" y="172" width="450" height="90">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 0"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[CONFIGURATION.showSeconds] == 0"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="@font/dseg7" size="68" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template><![CDATA[%02d:%02d:%02d]]>
                        <Parameter expression="[HOUR_1_12_Z]" />
                        <Parameter expression="[MINUTE_Z]" />
                        <Parameter expression="[SECOND_Z]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <!-- D-GHOST: 12H no seconds -->
        <PartText x="0" y="172" width="450" height="90" alpha="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 0"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[CONFIGURATION.showSeconds] == 1"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="@font/dseg7" size="82" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template>88:88</Template>
                </Font>
            </Text>
        </PartText>
        <!-- D-ACTIVE: 12H no seconds (larger font) -->
        <PartText x="0" y="172" width="450" height="90">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 0"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[CONFIGURATION.showSeconds] == 1"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="@font/dseg7" size="82" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template><![CDATA[%02d:%02d]]>
                        <Parameter expression="[HOUR_1_12_Z]" />
                        <Parameter expression="[MINUTE_Z]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <!-- ========================================================== -->
        <!-- AMBIENT TIME  HH:MM only monochrome, no ghost              -->
        <!-- ========================================================== -->
        <PartText x="0" y="172" width="450" height="90" alpha="0">
            <Variant mode="AMBIENT" target="alpha" value="255" />
            <Text align="CENTER">
                <Font family="@font/dseg7" size="82" weight="BOLD" color="#ff888888">
                    <Template><![CDATA[%02d:%02d]]>
                        <Parameter expression="[HOUR_0_23_Z]" />
                        <Parameter expression="[MINUTE_Z]" />
                    </Template>
                </Font>
            </Text>
        </PartText>

        <!-- ========================================================== -->
        <!-- SIDE INDICATORS: 24H / 12H / SIG / AM / PM                -->
        <!-- ========================================================== -->

        <!-- 24H label (shown when timeFormat=24h) -->
        <PartText x="390" y="188" width="50" height="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 1"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="12" weight="BOLD" letterSpacing="0.10" color="[CONFIGURATION.accentColor.2]">
                    <Template>24H</Template>
                </Font>
            </Text>
        </PartText>

        <!-- 12H label (shown when timeFormat=12h) -->
        <PartText x="390" y="188" width="50" height="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 0"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="12" weight="BOLD" letterSpacing="0.10" color="[CONFIGURATION.accentColor.2]">
                    <Template>12H</Template>
                </Font>
            </Text>
        </PartText>

        <!-- SIG label (24H mode) -->
        <PartText x="390" y="210" width="50" height="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 1"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="12" weight="BOLD" letterSpacing="0.10" color="[CONFIGURATION.accentColor.1]">
                    <Template>SIG</Template>
                </Font>
            </Text>
        </PartText>

        <!-- AM label (12H mode, before noon) -->
        <PartText x="390" y="210" width="50" height="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 0"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[HOUR_0_23] >= 12"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="12" weight="BOLD" letterSpacing="0.10" color="[CONFIGURATION.accentColor.1]">
                    <Template>AM</Template>
                </Font>
            </Text>
        </PartText>

        <!-- PM label (12H mode, noon onwards) -->
        <PartText x="390" y="210" width="50" height="18">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition expression="[CONFIGURATION.timeFormat] == 0"><Variant target="alpha" value="0" /></Condition>
            <Condition expression="[HOUR_0_23] < 12"><Variant target="alpha" value="0" /></Condition>
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="12" weight="BOLD" letterSpacing="0.10" color="[CONFIGURATION.accentColor.1]">
                    <Template>PM</Template>
                </Font>
            </Text>
        </PartText>

        <!-- ========================================================== -->
        <!-- DIVIDER  double line below time - active only              -->
        <!-- ========================================================== -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Line startX="82" startY="271" endX="368" endY="271">
                <Stroke color="[CONFIGURATION.accentColor.2]" thickness="2" />
            </Line>
            <Line startX="82" startY="275" endX="368" endY="275">
                <Stroke color="[CONFIGURATION.bgTheme.2]" thickness="1" />
            </Line>
        </PartDraw>

        <!-- ========================================================== -->
        <!-- BOTTOM PANEL 1: BATT with live progress bar - active only  -->
        <!-- ========================================================== -->
        <PartDraw x="62" y="283" width="96" height="66">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <RoundRectangle x="0" y="0" width="96" height="66" cornerRadiusX="4" cornerRadiusY="4">
                <Fill color="[CONFIGURATION.bgTheme.1]" />
                <Stroke color="[CONFIGURATION.bgTheme.2]" thickness="1" />
            </RoundRectangle>
        </PartDraw>
        <PartText x="62" y="287" width="96" height="16">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="11" weight="BOLD" letterSpacing="0.14" color="[CONFIGURATION.accentColor.2]">
                    <Template>BATT</Template>
                </Font>
            </Text>
        </PartText>
        <PartText x="62" y="305" width="96" height="28">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="20" weight="BOLD" color="[CONFIGURATION.accentColor.0]">
                    <Template><![CDATA[%d%%]]>
                        <Parameter expression="[BATTERY_PERCENT]" />
                    </Template>
                </Font>
            </Text>
        </PartText>
        <!-- Battery bar track (dim background) -->
        <PartDraw x="68" y="339" width="84" height="4">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Rectangle x="0" y="0" width="84" height="4">
                <Fill color="#22FFFFFF" />
            </Rectangle>
        </PartDraw>
        <!-- Battery bar fill - width driven by BATTERY_PERCENT expression -->
        <PartDraw x="68" y="339" width="84" height="4">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Rectangle x="0" y="0" width="[BATTERY_PERCENT]*84/100" height="4">
                <Fill color="[CONFIGURATION.accentColor.0]" />
            </Rectangle>
        </PartDraw>

        <!-- ========================================================== -->
        <!-- BOTTOM PANEL 2: ALT complication (user configurable)       -->
        <!-- ========================================================== -->
